# RS256 key setup:
# openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
# openssl rsa -pubout -in jwt-private.pem -out jwt-public.pem
# JWT_PRIVATE_KEY and JWT_PUBLIC_KEY can be the PEM content with escaped newlines
# or the single-line base64 body without BEGIN/END headers.
